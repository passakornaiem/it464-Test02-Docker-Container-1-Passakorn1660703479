# ระบุชื่อตัวแปรที่ใช้ใน compose.yaml เพื่อให้สอดคล้องกับการใช้งานในไฟล์นั้น
PROJECT_NAME=PROJECT_Eirth

MY_USERNAME=passakorn #ใส่ชื่อผู้ใช้ของคุณ
# พอร์ตที่ใช้สำหรับบริการต่าง ๆ
HTTP_PORT=80 # พอร์ตสำหรับ Web Proxy (Nginx)
Webserver_PORT=12601 # พอร์ตสำหรับ Web Server (PHP-FPM)
PMA_PORT=12602 # พอร์ตสำหรับ phpMyAdmin

# DB Details
DB_USER=root
DB_PASSWORD=password